# =====================================================
# AI Sales Lead Intelligence Platform — Environment Variables
# =====================================================
# Copy this file to .env.local and fill in your keys.
# NEVER commit .env.local to version control.

# NVIDIA NIM API (primary LLM + embeddings)
# Get yours at: https://build.nvidia.com/
NVIDIA_API_KEY=your_nvidia_api_key_here

# Groq API (fallback LLM)
# Get yours at: https://console.groq.com/
GROQ_API_KEY=your_groq_api_key_here

# Pinecone (vector database for RAG)
# Get yours at: https://app.pinecone.io/
PINECONE_API_KEY=your_pinecone_api_key_here

# Name of your Pinecone index (must be 1024-dim for NVIDIA embeddings)
PINECONE_INDEX_NAME=sales-leads-kb
