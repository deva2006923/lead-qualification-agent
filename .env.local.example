# ─────────────────────────────────────────────────────────────
# LeadIQ — Environment Variables Template
# Copy this file to .env.local for local development
# Set these as environment variables in Azure / AWS for production
# ─────────────────────────────────────────────────────────────

# LLM — Primary: Groq (https://console.groq.com)
GROQ_API_KEY=gsk_...

# Embeddings + LLM Fallback — NVIDIA NIM (https://build.nvidia.com)
NVIDIA_API_KEY=nvapi-...

# Vector DB — Pinecone (https://app.pinecone.io)
# Index must be 1024-dimensional (matches nvidia/nv-embedqa-e5-v5 output)
PINECONE_API_KEY=pcsk_...
PINECONE_INDEX_NAME=sales-leads-kb

# ─────────────────────────────────────────────────────────────
# PRODUCTION ONLY — Azure / AWS Deployment
# Set BACKEND_URL to your deployed FastAPI service URL
# Example: http://leadiq-backend.azurewebsites.net
# Example: http://ec2-xx-xx-xx.compute.amazonaws.com:8000
# Leave blank for local development (defaults to http://127.0.0.1:8000)
# ─────────────────────────────────────────────────────────────
BACKEND_URL=
